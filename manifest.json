{
  "manifest_version": 3,
  "name": "Video Auto Player",
  "version": "1.0.0",
  "description": "自适应网站视频自动播放器",
  "permissions": [
    "activeTabs",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/storage.js",
        "utils/adapter.js",
        "content/video-detector.js",
        "content/player-ui.js",
        "content/content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ]
}
